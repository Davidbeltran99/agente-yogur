{
  "name": "agente-yogur",
  "version": "1.0.0",
  "description": "Agente IA para pedidos de yogur con OpenAI, Node.js, SQLite y Google Sheets",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test:manual": "node scripts/test-message.js",
    "smoke:health": "node -e \"const axios=require('axios'); const port=process.env.PORT||3000; axios.get('http://127.0.0.1:'+port+'/health').then(r=>console.log(JSON.stringify(r.data,null,2))).catch(err=>{console.error(err.response?.data||err.message); process.exit(1);});\"",
    "validate:crm": "node scripts/validate-crm.js",
    "validate:catalog": "node scripts/validate-catalog-phase5a.js",
    "validate:multi-item": "node scripts/validate-multi-item-order.js",
    "validate:catalog-real": "node scripts/validate-catalog-real.js",
    "validate:catalog-sync": "node scripts/validate-catalog-sync.js",
    "validate:delivery-dates": "node scripts/validate-delivery-dates.js",
    "validate:hardening": "node scripts/validate-hardening.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^144.0.0"
  }
}
